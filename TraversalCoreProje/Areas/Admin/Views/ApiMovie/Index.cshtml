@model List<ApiMovieViewModel>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .movie-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: none;
        border-radius: 15px;
        overflow: hidden;
        background-color: #f8f9fa;
    }

        .movie-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
        }

    .movie-img-container {
        height: 350px;
        overflow: hidden;
    }

    .movie-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .imdb-badge {
        position: absolute;
        top: 10px;
        right: 10px;
        background-color: #f5c518; /* IMDB Sarısı */
        color: #000;
        font-weight: bold;
        padding: 5px 10px;
        border-radius: 8px;
    }

    .rank-badge {
        position: absolute;
        top: 10px;
        left: 10px;
        background-color: rgba(0, 0, 0, 0.7);
        color: #fff;
        padding: 5px 12px;
        border-radius: 8px;
        font-size: 0.9rem;
    }
</style>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">🎬 IMDB Top 100 Film Listesi</h2>
        <span class="badge bg-dark">Toplam @Model.Count Film</span>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 movie-card shadow-sm">
                    <div class="movie-img-container position-relative">
                        <span class="rank-badge">#@item.rank</span>
                        <span class="imdb-badge">⭐ @item.rating</span>
                        <img src="@item.image" class="card-img-top movie-img" alt="@item.title">
                    </div>

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold text-truncate">@item.title</h5>
                        <p class="text-muted small mb-3">Yapım Yılı: @item.year</p>

                        <div class="mt-auto">
                            <a href="#" class="btn btn-dark w-100 rounded-pill">
                                <i class="bi bi-play-fill"></i> Fragmanı İzle
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>