@model List<AppRole>
@{
	ViewData["Title"] = "Index";
	Layout = "~/Views/Shared/_AdminLayout.cshtml";
	var count = 0;
}

<h3>Rol Listesi</h3>


<table class="table table-bordered">
	<tr>
		<th>#</th>
		<th>Rol Adı</th>
		<th>Rolü Sil</th>
		<th>Rolü Güncelle</th>
	</tr>
	@if(Model.Count>0){
	@foreach (var item in Model)
	{
		count++;
		<tr>
			<td>@count</td>
			<td>@item.Name</td>
				<td><a href="/Admin/Role/DeleteRole/@item.Id" class="btn btn-danger">Sil</a></td>
				<td><a href="/Admin/Role/UpdateRole/@item.Id" class="btn btn-success">Güncelle</a></td>
		</tr>
		}
	}
	else
	{
		<tr class="alert alert-success">
			<td colspan="4" class="text-center">Hiç Rol Bulunamadı</td>
		</tr>
	}
</table>

<a href="/Admin/Role/CreateRole" class="btn btn-primary">Ekle</a>