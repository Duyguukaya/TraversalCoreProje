@model List<AppUser>
@{
    ViewData["Title"] = "UserList";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 0;
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h4 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-users-cog mr-2"></i>Kullanıcı Listesi
        </h4>
        <span class="badge badge-info">Toplam @Model.Count Kullanıcı</span>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover table-striped border shadow-sm" id="userTable">
                <thead class="thead-dark text-white">
                    <tr>
                        <th style="width: 50px;">#</th>
                        <th>Kullanıcı Adı</th>
                        <th>Ad Soyad</th>
                        <th class="text-center" style="width: 200px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        count++;
                        <tr>
                            <td class="align-middle font-weight-bold">@count</td>
                            <td class="align-middle">
                                <div class="d-flex align-items-center">
                                    <div class="avatar avatar-sm mr-3 bg-secondary text-white rounded-circle d-flex justify-content-center align-items-center" style="width: 35px; height: 35px;">
                                        @item.UserName.Substring(0, 1).ToUpper()
                                    </div>
                                    <span>@item.UserName</span>
                                </div>
                            </td>
                            <td class="align-middle">@item.Name @item.Surname</td>
                            <td class="text-center align-middle">
                                <a href="/Admin/Role/AssingRole/@item.Id" class="btn btn-outline-primary btn-sm rounded-pill px-3">
                                    <i class="fas fa-user-shield mr-1"></i> Rol Ata
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />

<style>
    .table thead th {
        border: none;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        font-size: 0.85rem;
    }
    .table-hover tbody tr:hover {
        background-color: rgba(78, 115, 223, 0.05);
        transition: 0.3s;
    }
    .btn-sm {
        font-size: 0.8rem;
    }
</style>