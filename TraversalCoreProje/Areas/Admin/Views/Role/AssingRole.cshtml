@model List<AssingRoleViewModel>
@{
    ViewData["Title"] = "AssingRole";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h3>Rol Atama Sayfası</h3>

<form method="post">
    @for(int i=0; i< Model.Count; i++)
    {
        <div class="form-check">
            <input type="hidden" asp-for="@Model[i].RoleId" />
            <input type="hidden" asp-for="@Model[i].RoleName" />

			<input type="checkbox" class="form-check-input" asp-for="@Model[i].RoleExist" />
            <label class="form-check-label" for="@Model[i].RoleExist">@Model[i].RoleName</label>
        </div>
    }
	<button class="btn btn-primary">Kaydet</button>
</form>

