@model List<AssingRoleViewModel>
@{
    ViewData["Title"] = "AssingRole";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 75vh;">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-lg border-0 rounded-lg">
            <div class="card-header bg-gradient-primary py-3">
                <h4 class="m-0 font-weight-bold text-white text-center">
                    <i class="fas fa-user-shield mr-2"></i>Rol Atama Paneli
                </h4>
            </div>
            <div class="card-body p-4">
                <p class="text-muted mb-4 text-center small">
                    Kullanıcıya tanımlamak istediğiniz rolleri aktif hale getirip kaydedebilirsiniz.
                </p>

                <form method="post">
                    <div class="list-group list-group-flush border-top border-bottom mb-4">
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center py-3 border-0">
                                <div>
                                    <h6 class="mb-0 font-weight-bold">@Model[i].RoleName</h6>
                                    <input type="hidden" asp-for="@Model[i].RoleId" />
                                    <input type="hidden" asp-for="@Model[i].RoleName" />
                                </div>
                                <div class="custom-control custom-switch custom-switch-md">
                                    <input type="checkbox" class="custom-control-input" id="role_@i" asp-for="@Model[i].RoleExist">
                                    <label class="custom-control-label cursor-pointer" for="role_@i"></label>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="d-flex justify-content-between">
                        <a href="/Admin/Role/UserList" class="btn btn-light btn-icon-split shadow-sm">
                            <span class="icon text-gray-600">
                                <i class="fas fa-arrow-left"></i>
                            </span>
                            <span class="text px-2">Geri Dön</span>
                        </a>
                        <button type="submit" class="btn btn-primary btn-icon-split shadow-sm">
                            <span class="icon text-white-50">
                                <i class="fas fa-check"></i>
                            </span>
                            <span class="text px-3">Değişiklikleri Kaydet</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>

    .bg-gradient-primary {
        background: linear-gradient(135deg, #4e73df 0%, #224abe 100%);
    }

    .custom-switch.custom-switch-md .custom-control-label::before {
        height: 1.5rem;
        width: 2.5rem;
        border-radius: 3rem;
    }

    .custom-switch.custom-switch-md .custom-control-label::after {
        width: calc(1.5rem - 4px);
        height: calc(1.5rem - 4px);
        border-radius: calc(2rem - (1.5rem / 2));
    }

    .custom-switch.custom-switch-md .custom-control-input:checked ~ .custom-control-label::after {
        transform: translateX(1rem);
    }

    .list-group-item:hover {
        background-color: #f8f9fc;
        transition: 0.2s;
    }

    .cursor-pointer {
        cursor: pointer;
    }

    .card {
        transition: transform 0.3s ease;
    }

        .card:hover {
            transform: translateY(-5px);
        }
</style>