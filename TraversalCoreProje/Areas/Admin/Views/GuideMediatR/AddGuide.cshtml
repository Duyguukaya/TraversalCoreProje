@model CreateGuideCommand

@{
    ViewData["Title"] = "AddGuide";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h3>CQRS MediatR Rehber Ekleme Sayfası</h3>

<form method="post">
    <label>Rehber Adı</label>
    <input type="text" asp-for="Name" class="form-control" />
    <br />
    <label>Açıklama</label>
    <input type="text" asp-for="Descrption" class="form-control" />
    <br />
    <button class="btn btn-outline-primary">Ekle</button>
</form>


