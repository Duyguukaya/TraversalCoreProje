@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

@await Html.PartialAsync("/Views/MemberLayoutPartial/_HeadPartial.cshtml")

<body class="g-sidenav-show bg-gray-100">

    @* @await Html.PartialAsync("/Views/MemberLayoutPartial/_NavbarPartial.cshtml") *@

    <aside class="sidenav navbar navbar-vertical navbar-expand-xs border-0 border-radius-xl my-3 fixed-start ms-3 " id="sidenav-main">
        <div class="sidenav-header">
            <i class="fas fa-times p-3 cursor-pointer text-secondary opacity-5 position-absolute end-0 top-0 d-none d-xl-none" aria-hidden="true" id="iconSidenav"></i>
            <a class="navbar-brand m-0" href=" https://demos.creative-tim.com/soft-ui-dashboard/pages/dashboard.html " target="_blank">
                <img src="~/soft-ui-dashboard-main/assets/img/logo-ct-dark.png" class="navbar-brand-img h-100" alt="main_logo">
                <span class="ms-1 font-weight-bold">Traversal Core Panel</span>
            </a>
        </div>
        <hr class="horizontal dark mt-0">
        <div class="collapse navbar-collapse w-auto h-100" id="sidenav-collapse-main">
            <ul class="navbar-nav">

                <li class="nav-item">
                    <a class="nav-link" href="/Member/Dashboard/Index/">
                        <div class="icon icon-shape icon-sm shadow border-radius-md bg-white text-center me-2 d-flex align-items-center justify-content-center">
                            <i class="fas fa-tachometer-alt text-dark"></i>
                        </div>
                        <span class="nav-link-text ms-1">@Localizer["İstatikler"]</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/Member/Destination/Index/">
                        <div class="icon icon-shape icon-sm shadow border-radius-md bg-white text-center me-2 d-flex align-items-center justify-content-center">
                            <i class="fas fa-route text-dark"></i>
                        </div>
                        <span class="nav-link-text ms-1">@Localizer["Rotalar"]</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link active" href="/Member/Profile/Index/">
                        <div class="icon icon-shape icon-sm shadow border-radius-md bg-white text-center me-2 d-flex align-items-center justify-content-center">
                            <i class="fas fa-user text-dark"></i>
                        </div>
                        <span class="nav-link-text ms-1">@Localizer["Profilim"]</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/Member/Reservation/MyCurrentReservation/">
                        <div class="icon icon-shape icon-sm shadow border-radius-md bg-white text-center me-2 d-flex align-items-center justify-content-center">
                            <i class="fas fa-calendar-check text-dark"></i>
                        </div>
                        <span class="nav-link-text ms-1">@Localizer["Aktif Rezervasyonlarım"]</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/Member/Reservation/MyOldReservation/">
                        <div class="icon icon-shape icon-sm shadow border-radius-md bg-white text-center me-2 d-flex align-items-center justify-content-center">
                            <i class="fas fa-history text-dark"></i>
                        </div>
                        <span class="nav-link-text ms-1">@Localizer["Geçmiş Rezervasyonlarım"]</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/Member/Reservation/MyApprovalReservation/">
                        <div class="icon icon-shape icon-sm shadow border-radius-md bg-white text-center me-2 d-flex align-items-center justify-content-center">
                            <i class="fas fa-hourglass-half text-dark"></i>
                        </div>
                        <span class="nav-link-text ms-1">@Localizer["Onay Bekleyenler"]</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/Member/Reservation/NewReservation/">
                        <div class="icon icon-shape icon-sm shadow border-radius-md bg-white text-center me-2 d-flex align-items-center justify-content-center">
                            <i class="fas fa-calendar-plus text-dark"></i>
                        </div>
                        <span class="nav-link-text ms-1">@Localizer["Rezervasyon Yap"]</span>
                    </a>
                </li>

                <li class="nav-item mt-3">
                    <h6 class="ps-4 ms-2 text-uppercase text-xs font-weight-bolder opacity-6">Account pages</h6>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/Default/Index">
                        <div class="icon icon-shape icon-sm shadow border-radius-md bg-white text-center me-2 d-flex align-items-center justify-content-center">
                            <i class="fas fa-globe text-dark"></i>
                        </div>
                        <span class="nav-link-text ms-1">@Localizer["Siteye Git"]</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/Login/LogOut/">
                        <div class="icon icon-shape icon-sm shadow border-radius-md bg-white text-center me-2 d-flex align-items-center justify-content-center">
                            <i class="fas fa-sign-out-alt text-dark"></i>
                        </div>
                        <span class="nav-link-text ms-1">@Localizer["Çıkış Yap"]</span>
                    </a>
                </li>
            </ul>
        </div>
    </aside>

    <main class="main-content position-relative max-height-vh-100 h-100 border-radius-lg ">

        @await Html.PartialAsync("/Views/MemberLayoutPartial/_Navbar2Partial.cshtml")

        <div class="container-fluid py-4 d-flex flex-column min-vh-100">
            @RenderBody()
            @await Html.PartialAsync("/Views/MemberLayoutPartial/_FooterPartial.cshtml")
        </div>

    </main>

    @await Html.PartialAsync("/Views/MemberLayoutPartial/_RightbarPartial.cshtml")

    @await Html.PartialAsync("/Views/MemberLayoutPartial/_ScriptPartial.cshtml")
    @RenderSection("Scripts", required: false)

</body>

</html>