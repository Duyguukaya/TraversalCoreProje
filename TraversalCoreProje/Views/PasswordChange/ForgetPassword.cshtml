@model ForgetPasswordViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Şifre Yenileme | Traversal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .forgot-card {
            background: rgba(255, 255, 255, 0.95);
            padding: 2.5rem;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
            width: 100%;
            max-width: 400px;
            transition: transform 0.3s ease;
        }

        .forgot-card:hover {
            transform: translateY(-5px);
        }

        h2 {
            font-weight: 600;
            color: #4a4a4a;
            margin-bottom: 1.5rem;
            text-align: center;
        }

        .form-label {
            font-size: 0.9rem;
            color: #666;
            font-weight: 500;
        }

        .form-control {
            border-radius: 10px;
            padding: 12px;
            border: 1px solid #ddd;
            transition: all 0.3s;
        }

        .form-control:focus {
            box-shadow: 0 0 0 3px rgba(118, 75, 162, 0.2);
            border-color: #764ba2;
        }

        .btn-submit {
            background: linear-gradient(to right, #667eea, #764ba2);
            border: none;
            border-radius: 10px;
            padding: 12px;
            font-weight: 600;
            width: 100%;
            margin-top: 1rem;
            color: white;
            transition: opacity 0.3s;
        }

        .btn-submit:hover {
            opacity: 0.9;
            color: white;
        }

        .back-to-login {
            display: block;
            text-align: center;
            margin-top: 1.5rem;
            font-size: 0.85rem;
            color: #764ba2;
            text-decoration: none;
        }
    </style>
</head>
<body>

    <div class="forgot-card">
        <h2>Şifre Yenileme</h2>
        <p class="text-muted text-center mb-4" style="font-size: 0.9rem;">
            Lütfen kayıtlı e-posta adresinizi girin. Size bir sıfırlama bağlantısı göndereceğiz.
        </p>

        <form method="post">
            <div class="mb-3">
                <label asp-for="Mail" class="form-label">E-posta Adresiniz</label>
                <input type="email" 
                       class="form-control" 
                       asp-for="Mail" 
                       placeholder="örnek@mail.com" 
                       required />
                <span asp-validation-for="Mail" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-submit shadow-sm">Talimat Gönder</button>
        </form>

        <a href="/Login/Index" class="back-to-login">← Giriş sayfasına dön</a>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>