@model ResetPasswordViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Yeni Şifre Belirle | Traversal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .reset-card {
            background: rgba(255, 255, 255, 0.95);
            padding: 2.5rem;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
            width: 100%;
            max-width: 450px;
            transition: transform 0.3s ease;
        }

        h2 {
            font-weight: 600;
            color: #4a4a4a;
            margin-bottom: 0.5rem;
            text-align: center;
        }

        .subtitle {
            font-size: 0.85rem;
            color: #777;
            text-align: center;
            margin-bottom: 2rem;
        }

        .form-label {
            font-size: 0.85rem;
            color: #555;
            font-weight: 500;
            margin-bottom: 5px;
        }

        .input-group-text {
            background-color: transparent;
            border-right: none;
            color: #764ba2;
        }

        .form-control {
            border-radius: 10px;
            padding: 12px;
            border: 1px solid #ddd;
            font-size: 0.95rem;
        }

            .form-control:focus {
                box-shadow: none;
                border-color: #764ba2;
            }

        /* Input grubu içinde border uyumu */
        .input-group .form-control {
            border-left: none;
        }

        .btn-submit {
            background: linear-gradient(to right, #667eea, #764ba2);
            border: none;
            border-radius: 10px;
            padding: 12px;
            font-weight: 600;
            width: 100%;
            margin-top: 1.5rem;
            color: white;
            transition: all 0.3s ease;
        }

            .btn-submit:hover {
                transform: scale(1.02);
                box-shadow: 0 5px 15px rgba(118, 75, 162, 0.3);
                color: white;
            }

        .text-danger {
            font-size: 0.75rem;
            margin-top: 4px;
            display: block;
        }
    </style>
</head>
<body>

    <div class="reset-card">
        <h2>Yeni Şifre Oluştur</h2>
        <p class="subtitle">Hesabınızın güvenliği için güçlü bir şifre belirleyin.</p>

        <form method="post">
            <div class="mb-3">
                <label asp-for="Password" class="form-label">Yeni Şifre</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-lock"></i></span>
                    <input type="password"
                           class="form-control"
                           asp-for="Password"
                           placeholder="••••••••"
                           required />
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label">Yeni Şifre (Tekrar)</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-check-double"></i></span>
                    <input type="password"
                           class="form-control"
                           asp-for="ConfirmPassword"
                           placeholder="••••••••"
                           required />
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-submit shadow-sm">Şifreyi Güncelle</button>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>